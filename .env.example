# ============================================
# 包装合规审核系统 — 环境变量配置
# 复制此文件为 .env.local 并填入真实 Key
# Vercel 部署时在 Settings → Environment Variables 中配置
# ============================================

# 豆包视觉识别 — OCR 文字提取（Doubao-Vision-Pro-32K）
# 来源：火山引擎 Ark API https://console.volcengine.com/ark
DOUBAO_API_KEY=
DOUBAO_API_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# DeepSeek — 文字分类 + 合规分析（V3 模型）
# 来源：https://platform.deepseek.com
DEEPSEEK_API_KEY=

# Kimi (Moonshot AI) — 合规分析备用管道
# 来源：https://platform.moonshot.ai
KIMI_API_KEY=
KIMI_API_BASE_URL=https://api.moonshot.cn/v1

# 阿里云百炼 DashScope — Qwen-VL 视觉识别（仅 debug 用，非主流程）
# 来源：https://bailian.console.aliyun.com
DASHSCOPE_API_KEY=

# Upstash Redis — 使用统计（可选，本地回退 localStorage）
# 来源：https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
