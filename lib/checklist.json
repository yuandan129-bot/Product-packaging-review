{
  "reviewChecklist": {
    "productIdentification": {
      "title": "一、产品识别",
      "items": [
        {
          "id": "PI-001",
          "name": "产品名称识别",
          "description": "识别包装上的产品名称",
          "severity": "critical",
          "standard": "GB 7718"
        },
        {
          "id": "PI-002",
          "name": "产品分类",
          "description": "判断产品类别（饮料、乳制品等）",
          "severity": "critical",
          "standard": "GB 7718"
        },
        {
          "id": "PI-003",
          "name": "执行标准号识别",
          "description": "识别并验证执行标准号",
          "severity": "critical",
          "standard": "GB 7718"
        }
      ]
    },
    "mandatoryElements": {
      "title": "二、强制标注内容检查（9大要素）",
      "items": [
        {
          "id": "ME-001",
          "name": "产品名称",
          "description": "是否标注了真实的产品名称",
          "severity": "critical",
          "standard": "GB 7718"
        },
        {
          "id": "ME-002",
          "name": "配料表",
          "description": "是否标注了完整的配料表，按含量从高到低排列",
          "severity": "critical",
          "standard": "GB 7718"
        },
        {
          "id": "ME-003",
          "name": "净含量/规格",
          "description": "是否标注了净含量，单位是否正确",
          "severity": "critical",
          "standard": "GB 7718"
        },
        {
          "id": "ME-004",
          "name": "生产日期",
          "description": "是否标注了生产日期，格式是否为YYYY.MM.DD",
          "severity": "critical",
          "standard": "GB 7718"
        },
        {
          "id": "ME-005",
          "name": "保质期",
          "description": "是否标注了保质期或保存期",
          "severity": "critical",
          "standard": "GB 7718"
        },
        {
          "id": "ME-006",
          "name": "贮存条件",
          "description": "是否标注了贮存条件",
          "severity": "critical",
          "standard": "GB 7718"
        },
        {
          "id": "ME-007",
          "name": "执行标准号",
          "description": "是否标注了执行标准号，是否为现行版本",
          "severity": "critical",
          "standard": "GB 7718"
        },
        {
          "id": "ME-008",
          "name": "生产许可证编号",
          "description": "是否标注了SC证号，格式是否正确（SC+14位数字）",
          "severity": "critical",
          "standard": "GB 7718"
        },
        {
          "id": "ME-009",
          "name": "生产商/经销者信息",
          "description": "是否标注了企业名称、地址、电话等完整信息",
          "severity": "critical",
          "standard": "GB 7718"
        }
      ]
    },
    "allergenCheck": {
      "title": "三、致敏原检查",
      "items": [
        {
          "id": "AC-001",
          "name": "致敏源识别",
          "description": "配料中是否含有常见致敏源（大豆、坚果、乳制品等）",
          "severity": "critical",
          "standard": "GB 7718"
        },
        {
          "id": "AC-002",
          "name": "致敏原标注",
          "description": "若含有致敏源，是否在显眼位置标注",
          "severity": "critical",
          "standard": "GB 7718"
        }
      ]
    },
    "nutritionLabel": {
      "title": "四、营养标签检查",
      "items": [
        {
          "id": "NL-001",
          "name": "5大营养成分",
          "description": "是否标注了能量、蛋白质、脂肪、碳水、钠",
          "severity": "critical",
          "standard": "GB 28050"
        },
        {
          "id": "NL-002",
          "name": "能量单位",
          "description": "能量单位是否为kJ",
          "severity": "critical",
          "standard": "GB 28050"
        },
        {
          "id": "NL-003",
          "name": "蛋白质/脂肪/碳水单位",
          "description": "蛋白质、脂肪、碳水单位是否为g",
          "severity": "critical",
          "standard": "GB 28050"
        },
        {
          "id": "NL-004",
          "name": "钠单位",
          "description": "钠单位是否为mg",
          "severity": "critical",
          "standard": "GB 28050"
        },
        {
          "id": "NL-005",
          "name": "能量值计算",
          "description": "能量值是否与计算值相符（±20%）",
          "severity": "high",
          "standard": "GB 28050",
          "formula": "能量(kJ) ≈ (蛋白质g×17 + 脂肪g×37 + 碳水g×17)"
        },
        {
          "id": "NL-006",
          "name": "修约间隔",
          "description": "营养成分的修约间隔是否符合规范",
          "severity": "high",
          "standard": "GB 28050"
        }
      ]
    },
    "additives": {
      "title": "五、食品添加剂检查",
      "items": [
        {
          "id": "AD-001",
          "name": "添加剂合规性",
          "description": "配料中的添加剂是否在GB 2760允许清单中",
          "severity": "critical",
          "standard": "GB 2760"
        },
        {
          "id": "AD-002",
          "name": "添加剂使用量",
          "description": "添加剂的使用量是否在规定范围内",
          "severity": "high",
          "standard": "GB 2760"
        }
      ]
    },
    "advertising": {
      "title": "六、广告文案检查",
      "items": [
        {
          "id": "AV-001",
          "name": "禁用词检查",
          "description": "是否包含禁用词汇（最、第一、唯一等）",
          "severity": "critical",
          "standard": "广告法"
        },
        {
          "id": "AV-002",
          "name": "医疗功效声称",
          "description": "是否包含医疗相关词汇（治疗、治愈等）",
          "severity": "critical",
          "standard": "广告法"
        },
        {
          "id": "AV-003",
          "name": "虚假信息",
          "description": "是否包含虚假的产地、认证或统计数据",
          "severity": "critical",
          "standard": "广告法"
        }
      ]
    },
    "fontAndLayout": {
      "title": "七、排版规范检查",
      "items": [
        {
          "id": "FL-001",
          "name": "强制内容字体高度",
          "description": "强制标注内容字体高度是否≥1.8mm",
          "severity": "high",
          "standard": "GB 7718"
        },
        {
          "id": "FL-002",
          "name": "净含量字体高度",
          "description": "净含量字体高度是否≥4mm",
          "severity": "high",
          "standard": "GB 7718"
        },
        {
          "id": "FL-003",
          "name": "条码规范",
          "description": "条码预留空白区和放置位置是否合理",
          "severity": "medium",
          "standard": "GB 7718"
        }
      ]
    },
    "brandConsistency": {
      "title": "八、品牌一致性检查",
      "items": [
        {
          "id": "BC-001",
          "name": "企业信息一致性",
          "description": "企业名称、地址、电话是否与品牌库一致",
          "severity": "high",
          "standard": "品牌资产库"
        },
        {
          "id": "BC-002",
          "name": "SC证号验证",
          "description": "SC证号格式是否正确（SC+14位数字）",
          "severity": "high",
          "standard": "GB 7718"
        }
      ]
    },
    "typoCheck": {
      "title": "九、错别字与措辞检测",
      "description": "OCR提取后逐项比对错别字词库，检测包装上的错别字、不规范措辞、单位格式错误",
      "items": [
        {
          "id": "TC-001",
          "name": "常见错别字",
          "description": "扫描OCR文字是否包含词库中的常见错字（如「保盾期」→「保质期」）",
          "severity": "critical",
          "standard": "错别字词库"
        },
        {
          "id": "TC-002",
          "name": "单位措辞规范",
          "description": "检查营养成分单位是否使用规范用法（如「千焦」→「kJ」）",
          "severity": "high",
          "standard": "GB 28050 / 措辞规范"
        },
        {
          "id": "TC-003",
          "name": "专业术语准确性",
          "description": "检查添加剂名称、标准号等专业术语是否正确",
          "severity": "critical",
          "standard": "GB 2760 / 错别字词库"
        },
        {
          "id": "TC-004",
          "name": "标签措辞一致性",
          "description": "检查如「致敏原」vs「过敏原」、「净含量」vs「净重量」等措辞是否统一",
          "severity": "high",
          "standard": "GB 7718"
        }
      ]
    }
  },
  "severityLevels": {
    "critical": {
      "level": 1,
      "description": "必须修改，违反法律法规",
      "color": "red"
    },
    "high": {
      "level": 2,
      "description": "建议修改，存在风险",
      "color": "orange"
    },
    "medium": {
      "level": 3,
      "description": "可选修改，优化建议",
      "color": "yellow"
    }
  }
}
